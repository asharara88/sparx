# Copy this file to .env and fill in the blanks. .env is gitignored — never commit it.
# Keys left blank fall back to mock implementations where supported, so the
# pipeline still runs unattended for local development.

# ── Pipeline runtime ─────────────────────────────────────────────
AUTO_APPROVE_GATES=false          # dev: set true to auto-pass gates and run unattended
BUDGET_CAP_USD=500
CHANNEL_NICHE=AI tools for creators
RENDER_FAKE=false                 # tests/dev: set true to skip the slow ffmpeg render step
LOG_LEVEL=info                    # debug|info|warn|error|silent
LOG_FORMAT=pretty                 # pretty|json

# ── LLM (mock fallback when key absent) ──────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-sonnet-4-6               # 'main' tier — economical default (qa/shorts/etc.)
LLM_FAST_MODEL=claude-haiku-4-5-20251001  # 'fast' tier — cheap grading/critique
LLM_PRO_MODEL=claude-fable-5              # 'pro' tier — Fable 5 at max effort, the creative spine: angle, script, packaging, visuals
LLM_MAX_RETRIES=3
LLM_TIMEOUT_MS=300000                     # Fable 5 turns at max effort can run minutes

# ── Research providers (mock fallback when absent) ───────────────
TAVILY_API_KEY=
BRAVE_API_KEY=

# ── Media providers (mock fallback when absent) ──────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (premade); swap for your cloned voice id
ELEVENLABS_VOICES=                          # optional: JSON array [{"id":"...","label":"..."}] for the dashboard voice picker
DEMO_MUSIC=                                 # optional: 1/true to mix an ElevenLabs music bed under demo:video (needs ELEVENLABS_API_KEY)
RUNWAY_API_KEY=
RUNWAY_MODEL=gen4.5
RUNWAY_IMAGE_MODEL=gen4_image   # text→image step (gen4.5 image-to-video needs a start image)
RUNWAY_API_BASE=https://api.dev.runwayml.com
RUNWAY_VERSION=2024-11-06
RUNWAY_POLL_TIMEOUT_MS=300000
RUNWAY_MAX_TAKES=1                # cap takes per shot to control API spend (1-4)
KLING_API_KEY=
PEXELS_API_KEY=
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=                 # your avatar id (GET https://api.heygen.com/v2/avatars)
HEYGEN_VOICE_ID=                  # your voice id  (GET https://api.heygen.com/v2/voices)
HEYGEN_API_BASE=https://api.heygen.com
HEYGEN_POLL_TIMEOUT_MS=300000    # production poll budget per avatar clip (5 min)
AVATAR_VOICE=auto                 # avatar lip-sync source: auto|elevenlabs|heygen
                                  #   elevenlabs = narrate with your ElevenLabs voice, upload to HeyGen, mouth synced to that audio
                                  #   heygen     = HeyGen's built-in TTS speaks HEYGEN_VOICE_ID
                                  #   auto       = elevenlabs when ELEVENLABS_API_KEY is set, else heygen
DEMO_HEYGEN_POLL_TIMEOUT_MS=     # optional: demo:video poll budget (defaults to min(2min, above))
DEMO_CONCURRENCY=2               # demo:video sections rendered in parallel (1-4; mind provider quotas)
YOUTUBE_ACCESS_TOKEN=             # static OAuth token (~1h), scope youtube.upload — for one-off tests
# Durable upload (recommended for unattended runs): set all three and the app
# auto-mints fresh access tokens from the refresh token.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CATEGORY_ID=27            # 27 = Education
YOUTUBE_PRIVACY=private           # private|unlisted|public

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=

# ── Browser control ──────────────────────────────────────────────
PLAYWRIGHT_MODE=headless          # headless|headed
CHROME_CDP_ENDPOINT=
